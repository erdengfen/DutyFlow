# DutyFlow Demo 环境配置示例，真实密钥只允许写入本地 .env

# Agent 内部模型调用配置
DUTYFLOW_MODEL_API_KEY=replace-with-model-api-key
DUTYFLOW_MODEL_BASE_URL=https://example-model-endpoint.invalid
DUTYFLOW_MODEL_NAME=demo-model

# 飞书接入配置
# 已确认基础字段：App ID、App Secret、Encrypt Key、Verification Token
# 暂定字段：EVENT_CALLBACK_URL，真实接入飞书开放平台时需要核实
DUTYFLOW_FEISHU_APP_ID=replace-with-feishu-app-id
DUTYFLOW_FEISHU_APP_SECRET=replace-with-feishu-app-secret
DUTYFLOW_FEISHU_EVENT_VERIFY_TOKEN=replace-with-feishu-event-token
DUTYFLOW_FEISHU_EVENT_ENCRYPT_KEY=replace-with-feishu-encrypt-key
DUTYFLOW_FEISHU_EVENT_CALLBACK_URL=https://example-callback.invalid/feishu/events

# 本地文件存储配置
DUTYFLOW_DATA_DIR=data
DUTYFLOW_LOG_DIR=data/logs
DUTYFLOW_RUNTIME_ENV=local-demo
DUTYFLOW_LOG_LEVEL=INFO
